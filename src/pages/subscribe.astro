---
import SiteLayout from "../layouts/SiteLayout.astro";

const subscribeOptions = [
  {
    title: "RSS Feed",
    kicker: "PRIMARY FEED",
    description: "适合放进播客播放器、阅读器或自动化工具里，稳定跟住每一次更新。",
    detail: "复制或打开 /podcast-site/rss.xml",
    href: "/podcast-site/rss.xml",
    action: "打开 RSS Feed",
  },
  {
    title: "Apple Podcasts",
    kicker: "PODCAST PLATFORM",
    description: "接通后会作为标准播客平台入口，方便在 Apple 生态里直接订阅收听。",
    detail: "待配置",
    action: "待配置",
    disabled: true,
  },
  {
    title: "小宇宙",
    kicker: "CHINESE PODCAST",
    description: "后续会补齐真实节目入口，方便在中文播客客户端里继续跟更。",
    detail: "待配置",
    action: "待配置",
    disabled: true,
  },
  {
    title: "邮件联系",
    kicker: "EMAIL",
    description: "如果你想反馈节目线索、订阅问题或合作信息，可以直接发邮件联系。",
    detail: "xiaoyao20120709@163.com",
    href: "mailto:xiaoyao20120709@163.com",
    action: "发送邮件",
  },
  {
    title: "飞书联系",
    kicker: "FEISHU",
    description: "用于后续同步社群、文档或工作流入口，当前先保留为占位入口。",
    detail: "待配置",
    action: "待配置",
    disabled: true,
  },
];
---

<SiteLayout title="订阅" description="订阅 AI观测站">
  <div class="subscribe-page">
    <section class="subscribe-hero">
      <div class="container subscribe-hero-grid">
        <div>
          <p class="subscribe-kicker">SUBSCRIBE</p>
          <h1>选择顺手的方式</h1>
          <p class="subscribe-lead">三种订阅方式，任何一个都能第一时间收到新节目。</p>
        </div>

        <div class="subscribe-hero-panel">
          <span>RSS / Platform / Contact</span>
          <strong>把 AI 观测站接进你的日常信息流</strong>
          <p>优先推荐 RSS；平台入口未配置前保持占位，避免跳到错误地址。</p>
        </div>
      </div>
    </section>

    <section class="subscribe-section">
      <div class="container subscribe-grid">
        {subscribeOptions.map((option) => {
          const CardTag = option.href && !option.disabled ? "a" : "article";

          return (
            <CardTag class:list={["subscribe-card", option.disabled && "is-disabled"]} href={option.href}>
              <p class="subscribe-card-kicker">{option.kicker}</p>
              <h2>{option.title}</h2>
              <p class="subscribe-muted">{option.description}</p>
              <span class="subscribe-detail">{option.detail}</span>
              <span class:list={["subscribe-action", option.disabled && "is-secondary"]}>{option.action}</span>
            </CardTag>
          );
        })}
      </div>
    </section>
  </div>
</SiteLayout>
