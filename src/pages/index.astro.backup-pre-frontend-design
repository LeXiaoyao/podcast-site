---
import EpisodeCard from "../components/EpisodeCard.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  formatZhDate,
  getCategorySummaries,
  getCategoryUrl,
  getPublishedEpisodes,
} from "../lib/episodes";
import { SITE } from "../lib/site";

const episodes = await getPublishedEpisodes();
const [latestEpisode, ...restEpisodes] = episodes;
const categorySummaries = getCategorySummaries(episodes).slice(0, 5);
const totalMinutes = Math.round(
  episodes.reduce((sum, episode) => sum + episode.data.durationSeconds, 0) / 60,
);
---

<SiteLayout>
  <section class="hero-section home-hero">
    <div class="container hero-grid hero-grid-home">
      <div class="hero-copy hero-copy-home">
        <p class="hero-kicker">AI OBSERVATORY · PODCAST ARCHIVE</p>
        <h1>
          每天十分钟，
          <em>听懂 AI 产业链</em>
        </h1>
        <p class="hero-tagline">{SITE.slogan}</p>
        <p class="hero-description">
          把散落在模型、芯片、产品、组织和资本市场里的 AI 变化，整理成可收听、可搜索、
          可沉淀的节目页面。
        </p>

        <div class="hero-actions">
          <a class="button-primary" href="/episodes/">开始浏览</a>
          <a class="button-secondary" href="/subscribe/">订阅更新</a>
        </div>

        <div class="hero-stats">
          <div class="stat-card">
            <strong>{episodes.length}</strong>
            <span>已收录节目</span>
          </div>
          <div class="stat-card">
            <strong>{totalMinutes}</strong>
            <span>累计分钟</span>
          </div>
          <div class="stat-card">
            <strong>{categorySummaries.length}</strong>
            <span>核心分类</span>
          </div>
        </div>
      </div>

      <div class="hero-panel signal-panel">
        <p class="panel-kicker">本周节目信号</p>
        <div class="signal-orb">
          <span>AI</span>
        </div>
        <div class="signal-list">
          <div class="signal-item">
            <strong>{latestEpisode ? formatZhDate(latestEpisode.data.pubDate) : "持续更新中"}</strong>
            <span>最近一次发布</span>
          </div>
          <div class="signal-item">
            <strong>{latestEpisode?.data.category ?? "资讯速报"}</strong>
            <span>当前主打内容线</span>
          </div>
          <div class="signal-item">
            <strong>{latestEpisode?.data.tags.slice(0, 2).join(" / ") || "节目档案持续扩充"}</strong>
            <span>最新一期关键词</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="container section-head">
      <div>
        <p class="section-kicker">最新一期</p>
        <h2>先把最值得打开的一期放到首页中央</h2>
      </div>
      <a class="text-link" href="/episodes/">进入节目库</a>
    </div>

    <div class="container">
      {latestEpisode ? <EpisodeCard episode={latestEpisode} featured /> : <p>还没有可展示的节目内容。</p>}
    </div>
  </section>

  <section class="section-block">
    <div class="container section-head">
      <div>
        <p class="section-kicker">这个站在做什么</p>
        <h2>不是博客壳子，而是播客前台</h2>
      </div>
    </div>

    <div class="container insight-grid">
      <article class="insight-card">
        <strong>节目页</strong>
        <p>每一期都有独立 URL、完整 shownotes、参考资料和可回流的 SEO 着陆页。</p>
      </article>
      <article class="insight-card">
        <strong>分类页</strong>
        <p>按内容意图组织，而不是只按发布日期堆叠，让旧内容持续被找到。</p>
      </article>
      <article class="insight-card">
        <strong>RSS</strong>
        <p>网站和 RSS 共用一份内容源，后面可以逐步替代不稳定的平台逆向发布链路。</p>
      </article>
    </div>
  </section>

  <section class="section-block">
    <div class="container section-head">
      <div>
        <p class="section-kicker">分类入口</p>
        <h2>先给听众一个清晰的信息地图</h2>
      </div>
      <a class="text-link" href="/categories/">查看全部分类</a>
    </div>

    <div class="container category-grid">
      {categorySummaries.map((category) => (
        <a class="category-card" href={getCategoryUrl(category.name)}>
          <strong>{category.name}</strong>
          <p>{category.description}</p>
          <span>{category.count} 期节目</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="container section-head">
      <div>
        <p class="section-kicker">最近更新</p>
        <h2>让首页本身就是一个可滚动的节目流</h2>
      </div>
    </div>

    <div class="container episode-stack">
      {restEpisodes.slice(0, 6).map((episode) => <EpisodeCard episode={episode} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="container info-grid">
      <article class="subscribe-panel">
        <p class="section-kicker">订阅入口</p>
        <h2>先把 RSS 和品牌官网打通</h2>
        <p>
          这版先保证标准 RSS、节目详情页和官网入口都在一条线上，后面再继续接平台分发和更强的播放器体验。
        </p>
        <div class="hero-actions">
          <a class="button-primary" href="/rss.xml">打开 RSS</a>
          <a class="button-secondary" href="/subscribe/">查看订阅方式</a>
        </div>
      </article>

      <article class="about-panel">
        <p class="section-kicker">关于节目</p>
        <h2>{SITE.title}</h2>
        <p>
          围绕 AI 行业、产品、基础设施和组织变化，持续沉淀适合听、也适合搜索引擎索引的内容资产。
        </p>
        <a class="text-link" href="/about/">了解更多</a>
      </article>
    </div>
  </section>
</SiteLayout>
