---
// src/pages/index.astro — 完整替换版本
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  formatZhDate,
  getCategorySummaries,
  getCategoryUrl,
  getEpisodeCoverUrl,
  getEpisodeUrl,
  getPublishedEpisodes,
} from "../lib/episodes";
import { SITE } from "../lib/site";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const episodes = await getPublishedEpisodes();
const [latest, ...rest] = episodes;
const recentEpisodes = rest.slice(0, 6);
const categorySummaries = getCategorySummaries(episodes).slice(0, 6);

const latestCover   = latest ? getEpisodeCoverUrl(latest)  : `${base}/cover-placeholder.svg`;
const latestUrl     = latest ? getEpisodeUrl(latest)        : `${base}/episodes/`;
const latestDate    = latest ? formatZhDate(latest.data.pubDate) : "";
const latestTags    = latest?.data.tags.slice(0, 3) ?? [];

const totalMinutes  = Math.round(
  episodes.reduce((s, e) => s + e.data.durationSeconds, 0) / 60,
);

const PLATFORMS = {
  xiaoyuzhou: "https://www.xiaoyuzhoufm.com/podcast/69bcbc3f0e7cef5a34d09492",
  apple: "https://podcasts.apple.com/us/podcast/ai%E8%A7%82%E6%B5%8B%E7%AB%99-ai-observatory/id1887157488?l=zh-Hans-CN",
  rss: `${base}/rss.xml`,
};
---

<SiteLayout>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="home-hero">
    <div class="container">
      <div class="home-hero-grid">

        <!-- Left copy -->
        <div>
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            <span class="hero-badge-text">AI OBSERVATORY · 持续更新中</span>
          </div>

          <h1 class="hero-h1">{SITE.title}</h1>

          <p class="hero-tagline">
            每天追踪 AI 产业、产品、模型、资本与大厂动态，用一档播客帮你看懂 AI 正在怎么改变世界。
          </p>

          <div class="hero-actions">
            {latest ? (
              <a href={`${base}${latestUrl}`} class="btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5,3 19,12 5,21"/></svg>
                收听最新一期
              </a>
            ) : (
              <a href={`${base}/episodes/`} class="btn-primary">进入节目流</a>
            )}
            <a href={`${base}/subscribe/`} class="btn-ghost">
              订阅节目 / RSS →
            </a>
          </div>

          <div class="hero-stats">
            <div>
              <div class="hero-stat-val">{episodes.length}+</div>
              <div class="hero-stat-label">期节目</div>
            </div>
            <div>
              <div class="hero-stat-val">{totalMinutes}+</div>
              <div class="hero-stat-label">分钟内容</div>
            </div>
            <div>
              <div class="hero-stat-val">{categorySummaries.length}</div>
              <div class="hero-stat-label">内容栏目</div>
            </div>
          </div>
        </div>

        <!-- Right: latest cover -->
        {latest && (
          <div class="hero-cover-wrap">
            <a href={`${base}${latestUrl}`} class="hero-cover-img">
              <img
                src={latestCover}
                alt={latest.data.title}
                loading="eager"
                decoding="async"
              />
            </a>
            <div class="hero-cover-badge">
              LATEST · {latestDate}
            </div>
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- ── Latest episode ────────────────────────────────────── -->
  {latest && (
    <section class="latest-section">
      <div class="container">
        <div class="latest-section-head">
          <div>
            <div class="kicker" style="margin-bottom:6px">LATEST EPISODE</div>
            <h2 style="font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,1.9rem);letter-spacing:-0.04em;color:#f0f6ff">最新一期</h2>
          </div>
        </div>

        <a href={`${base}${latestUrl}`} class="latest-card">
          <div class="latest-grid">
            <!-- Cover -->
            <div class="latest-cover">
              <img
                src={latestCover}
                alt={latest.data.title}
                loading="eager"
                decoding="async"
              />
            </div>
            <!-- Copy -->
            <div class="latest-copy">
              <div class="latest-meta">
                <span class="tag tag-cat">{latest.data.category}</span>
                <span class="latest-meta-date">
                  EP.{String(episodes.indexOf(latest) + 1).padStart(3,"0")} · {latestDate} · {latest.data.duration}
                </span>
              </div>

              <h3 class="latest-title">{latest.data.title}</h3>

              <p class="latest-summary">{latest.data.description}</p>

              <div class="latest-tags">
                {latestTags.map((t) => (
                  <span class="tag">#{t}</span>
                ))}
              </div>

              <div class="latest-actions">
                <span class="btn-primary" style="pointer-events:none">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5,3 19,12 5,21"/></svg>
                  播放本期
                </span>
                <span class="btn-ghost" style="pointer-events:none;font-size:0.88rem">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  查看 Shownotes
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ── Categories ────────────────────────────────────────── -->
  {categorySummaries.length > 0 && (
    <section class="cats-section">
      <div class="container">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
          <div>
            <div class="kicker" style="margin-bottom:5px">BROWSE BY TOPIC</div>
            <h2 style="font-family:var(--font-display);font-weight:900;font-size:clamp(1.2rem,2.5vw,1.5rem);letter-spacing:-0.04em;color:#f0f6ff">按主题找节目</h2>
          </div>
        </div>
        <div class="cats-bar">
          <a href={`${base}/episodes/`} class="cat-btn">全部节目</a>
          {categorySummaries.map((cat) => (
            <a href={`${base}${getCategoryUrl(cat.name)}`} class="cat-btn">
              {cat.name} · {cat.count}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Recent stream ─────────────────────────────────────── -->
  {recentEpisodes.length > 0 && (
    <section class="stream-section">
      <div class="container">
        <div class="stream-head">
          <div>
            <div class="kicker" style="margin-bottom:5px">RECENT STREAM</div>
            <h2 style="font-family:var(--font-display);font-weight:900;font-size:clamp(1.2rem,2.5vw,1.5rem);letter-spacing:-0.04em;color:#f0f6ff">往期节目</h2>
          </div>
          <a href={`${base}/episodes/`} class="btn-ghost" style="font-size:0.88rem;padding:9px 16px">
            查看全部 {episodes.length} 期 →
          </a>
        </div>

        <div class="stream-grid">
          {recentEpisodes.map((ep) => {
            const cover = getEpisodeCoverUrl(ep);
            const tags  = ep.data.tags.slice(0, 3);
            return (
              <a href={`${base}${getEpisodeUrl(ep)}`} class="stream-card">
                <div class="stream-card-inner">
                  <div class="stream-cover">
                    <img src={cover} alt={ep.data.title} loading="lazy" decoding="async" />
                  </div>
                  <div class="stream-body">
                    <div class="stream-meta">
                      <span class="tag tag-cat" style="font-size:0.68rem;padding:3px 8px">{ep.data.category}</span>
                      <span class="stream-meta-date">{formatZhDate(ep.data.pubDate)} · {ep.data.duration}</span>
                    </div>
                    <h3 class="stream-title">{ep.data.title}</h3>
                    <p class="stream-desc">{ep.data.description}</p>
                    <div class="stream-tags">
                      {tags.map((t) => (
                        <span class="tag" style="font-size:0.66rem;padding:3px 8px">#{t}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <div style="text-align:center;margin-top:28px">
          <a href={`${base}/episodes/`} class="btn-ghost" style="font-size:0.88rem">
            查看全部 {episodes.length} 期节目 →
          </a>
        </div>
      </div>
    </section>
  )}

</SiteLayout>
